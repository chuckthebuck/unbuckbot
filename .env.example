# OAuth consumer (Wikimedia OAuth2)
OAUTH_CLIENT_ID=replace-me
OAUTH_CLIENT_SECRET=replace-me
OAUTH_CALLBACK_URL=https://YOUR-TOOL.toolforge.org/api/v1/auth/callback

# Bot account credentials (Commons)
BOT_USERNAME=YourBot@tool
BOT_PASSWORD=replace-me

# Tool identity
TOOL_USER_AGENT=buckbotchucker/1.0 (https://github.com/chuckthebuck/unbuckbot; alachuckthebuck@protonmail.org)

# Requester policy controls
WHITELIST_ONLY=1
DEFAULT_JOBS_PER_MINUTE=2
DEFAULT_MAX_ITEMS_PER_JOB=100
REQUESTER_POLICIES_FILE=config/requester_policies.json
# Optional override (takes precedence over REQUESTER_POLICIES_FILE)
# REQUESTER_POLICIES_JSON={"Alachuckthebuck":{"jobs_per_minute":10,"max_items_per_job":400}}
